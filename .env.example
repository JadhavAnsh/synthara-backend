# Core backend runtime
SYNTHARA_PROVIDER_TIMEOUT_SECONDS=15
SYNTHARA_MAX_ITERATIONS=2
SYNTHARA_MAX_SOURCES_PER_PROVIDER=4
SYNTHARA_MIN_ACCEPTED_SOURCES=3

# Tavily web search
SYNTHARA_TAVILY_API_KEY=
SYNTHARA_TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
SYNTHARA_TAVILY_SEARCH_DEPTH=advanced

# alphaXiv bridge
SYNTHARA_ALPHAXIV_BRIDGE_URL=http://127.0.0.1:4100
SYNTHARA_ALPHAXIV_BRIDGE_TIMEOUT_SECONDS=20

# Gemini generation
SYNTHARA_GEMINI_API_KEY=
SYNTHARA_GEMINI_MODEL=gemini-2.5-flash
